<Window x:Class="SynologyPhotoFrame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SynologyPhotoFrame.Views"
        xmlns:vm="clr-namespace:SynologyPhotoFrame.ViewModels"
        mc:Ignorable="d"
        Title="Synology Photo Frame"
        Height="768" Width="1024"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        Icon="Resources/app.ico">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AlbumSelectionViewModel}">
            <views:AlbumSelectionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SlideshowViewModel}">
            <views:SlideshowView/>
        </DataTemplate>
    </Window.Resources>

    <ContentControl Content="{Binding CurrentView}"/>
</Window>
