<UserControl x:Class="SynologyPhotoFrame.Views.SlideshowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:SynologyPhotoFrame.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1280"
             Focusable="True"
             KeyDown="OnKeyDown"
             MouseMove="OnMouseMove">

    <Grid Background="Black">
        <!-- Photo Display (hidden when schedule-paused) -->
        <Grid Visibility="{Binding IsSchedulePaused, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <controls:TransitionPresenter x:Name="TransitionControl"
                                           TransitionDuration="1.0"/>

            <!-- Loading Overlay -->
            <Grid Background="#80000000"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Loading photos..." FontSize="24" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="16" Foreground="#ff4444"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>

            <!-- Clock (top-right) -->
            <TextBlock Text="{Binding CurrentTimeDisplay}"
                       FontSize="32" Foreground="#AAFFFFFF"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,16,24,0"
                       Visibility="{Binding ShowClock, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Photo Info (bottom-left) -->
            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Margin="24,0,0,24"
                        Visibility="{Binding ShowPhotoInfo, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock FontSize="14" Foreground="#AAFFFFFF">
                    <Run Text="{Binding CurrentPhotoInfo, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock FontSize="14" Foreground="#88FFFFFF">
                    <Run Text="{Binding CurrentIndex, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TotalPhotos, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>

            <!-- Overlay Controls -->
            <Grid x:Name="OverlayGrid"
                  Visibility="{Binding IsOverlayVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <!-- Semi-transparent background -->
                <Grid Background="#40000000"/>

                <!-- Top bar -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="16">
                    <Button Content="&#x2699;" Style="{StaticResource IconButton}"
                            Click="OnSettingsClick" ToolTip="Settings"/>
                    <Button Content="&#x26F6;" Style="{StaticResource IconButton}"
                            Click="OnFullScreenClick" ToolTip="Toggle Fullscreen"/>
                    <Button Content="&#x2716;" Style="{StaticResource IconButton}"
                            Click="OnBackClick" ToolTip="Back"/>
                </StackPanel>

                <!-- Center controls -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="&#x25C0;" Style="{StaticResource IconButton}"
                            FontSize="36" Width="72" Height="72"
                            Command="{Binding ShowPreviousPhotoCommand}"/>
                    <Button Style="{StaticResource IconButton}"
                            FontSize="36" Width="72" Height="72" Margin="24,0"
                            Command="{Binding TogglePauseCommand}">
                        <Button.Content>
                            <TextBlock Text="{Binding IsPaused, Converter={StaticResource BoolToPauseIconConverter}}"/>
                        </Button.Content>
                    </Button>
                    <Button Content="&#x25B6;" Style="{StaticResource IconButton}"
                            FontSize="36" Width="72" Height="72"
                            Command="{Binding ShowNextPhotoCommand}"/>
                </StackPanel>

                <!-- Photo counter (bottom) -->
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Margin="0,0,0,24" FontSize="16" Foreground="#CCFFFFFF">
                    <Run Text="{Binding CurrentIndex, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TotalPhotos, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Grid>

        <!-- Settings Panel -->
        <Grid x:Name="SettingsPanel" Visibility="Collapsed">
            <Grid Background="#E0000000" MouseLeftButtonDown="OnSettingsBackgroundClick"/>
            <Border Background="{StaticResource SecondaryDarkBrush}"
                    CornerRadius="16"
                    MinWidth="480" MaxWidth="560"
                    Margin="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="32,28"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                        <!-- Playback Section -->
                        <TextBlock Text="PLAYBACK" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Photo interval" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="15" VerticalAlignment="Center"/>
                            <ComboBox x:Name="IntervalCombo" Grid.Column="1"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Transition effect" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="15" VerticalAlignment="Center"/>
                            <ComboBox x:Name="TransitionCombo" Grid.Column="1"/>
                        </Grid>

                        <CheckBox x:Name="ShuffleCheck" Content="Shuffle photos" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ClockCheck" Content="Show clock" Margin="0,0,0,8"/>
                        <CheckBox x:Name="PhotoInfoCheck" Content="Show photo info" Margin="0,0,0,4"/>

                        <!-- Separator -->
                        <Rectangle Height="1" Fill="#E2E8F0" Margin="0,16,0,16"/>

                        <!-- Schedule Section -->
                        <TextBlock Text="SCHEDULE" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <CheckBox x:Name="ScheduleCheck" Content="Enable daily schedule" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Active hours" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="15" VerticalAlignment="Center"/>
                            <TextBox x:Name="StartTimeBox" Grid.Column="1" MaxLength="5"
                                     MinWidth="80" HorizontalContentAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="-" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="18"
                                       Margin="0,0,12,0"/>
                            <TextBox x:Name="EndTimeBox" Grid.Column="4" MaxLength="5"
                                     MinWidth="80" MaxWidth="80" HorizontalContentAlignment="Center"/>
                        </Grid>

                        <!-- Separator -->
                        <Rectangle Height="1" Fill="#E2E8F0" Margin="0,16,0,16"/>

                        <!-- Storage Section -->
                        <TextBlock Text="STORAGE" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <TextBlock x:Name="CacheSizeText" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14" Margin="0,0,0,8"/>
                        <Button Content="Clear Cache" Style="{StaticResource GhostButton}"
                                Click="OnClearCacheClick" HorizontalAlignment="Left"
                                Margin="0,0,0,4"/>

                        <!-- Separator -->
                        <Rectangle Height="1" Fill="#E2E8F0" Margin="0,16,0,20"/>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" Style="{StaticResource GhostButton}"
                                    Margin="0,0,12,0" Click="OnSettingsCancelClick"/>
                            <Button Content="Save" Style="{StaticResource PrimaryButton}"
                                    Click="OnSettingsSaveClick"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
