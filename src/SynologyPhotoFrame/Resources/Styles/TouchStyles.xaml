<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Touch-friendly TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="Background" Value="#F1F5F9"/>
        <Setter Property="Foreground" Value="#1E293B"/>
        <Setter Property="CaretBrush" Value="#1E293B"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Touch-friendly PasswordBox -->
    <Style TargetType="PasswordBox">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="Background" Value="#F1F5F9"/>
        <Setter Property="Foreground" Value="#1E293B"/>
        <Setter Property="CaretBrush" Value="#1E293B"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
    </Style>

    <!-- Touch-friendly CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="Padding" Value="8,0,0,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="#1E293B"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>

    <!-- Touch-friendly ScrollViewer -->
    <Style TargetType="ScrollViewer">
        <Setter Property="PanningMode" Value="Both"/>
        <Setter Property="PanningDeceleration" Value="0.002"/>
        <Setter Property="PanningRatio" Value="1"/>
    </Style>

    <!-- Touch-friendly ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="MinHeight" Value="48"/>
    </Style>

    <!-- Touch-friendly Slider -->
    <Style TargetType="Slider">
        <Setter Property="MinHeight" Value="48"/>
    </Style>
</ResourceDictionary>
