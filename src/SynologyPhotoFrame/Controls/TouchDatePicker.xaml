<UserControl x:Class="SynologyPhotoFrame.Controls.TouchDatePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SpinButton" TargetType="RepeatButton">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Delay" Value="400"/>
            <Setter Property="Interval" Value="200"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ValueTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,4,0,0"/>
            <Setter Property="CaretBrush" Value="#3B82F6"/>
        </Style>

        <Style x:Key="ClearButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <!-- Year spinner -->
        <StackPanel>
            <RepeatButton Content="&#x25B2;" Style="{StaticResource SpinButton}" Click="OnYearUp"/>
            <Border Background="#F1F5F9" CornerRadius="6" Margin="0,3">
                <TextBox x:Name="YearText" Text="----"
                         Style="{StaticResource ValueTextBox}"
                         Width="64" Height="36"
                         MaxLength="4"
                         GotFocus="OnTextBoxGotFocus"
                         LostFocus="OnYearLostFocus"
                         KeyDown="OnTextBoxKeyDown"/>
            </Border>
            <RepeatButton Content="&#x25BC;" Style="{StaticResource SpinButton}" Click="OnYearDown"/>
        </StackPanel>

        <TextBlock Text="/" FontSize="22" FontWeight="Bold"
                   Foreground="#94A3B8" VerticalAlignment="Center" Margin="4,0"/>

        <!-- Month spinner -->
        <StackPanel>
            <RepeatButton Content="&#x25B2;" Style="{StaticResource SpinButton}" Click="OnMonthUp"/>
            <Border Background="#F1F5F9" CornerRadius="6" Margin="0,3">
                <TextBox x:Name="MonthText" Text="--"
                         Style="{StaticResource ValueTextBox}"
                         Width="52" Height="36"
                         MaxLength="2"
                         GotFocus="OnTextBoxGotFocus"
                         LostFocus="OnMonthLostFocus"
                         KeyDown="OnTextBoxKeyDown"/>
            </Border>
            <RepeatButton Content="&#x25BC;" Style="{StaticResource SpinButton}" Click="OnMonthDown"/>
        </StackPanel>

        <TextBlock Text="/" FontSize="22" FontWeight="Bold"
                   Foreground="#94A3B8" VerticalAlignment="Center" Margin="4,0"/>

        <!-- Day spinner -->
        <StackPanel>
            <RepeatButton Content="&#x25B2;" Style="{StaticResource SpinButton}" Click="OnDayUp"/>
            <Border Background="#F1F5F9" CornerRadius="6" Margin="0,3">
                <TextBox x:Name="DayText" Text="--"
                         Style="{StaticResource ValueTextBox}"
                         Width="52" Height="36"
                         MaxLength="2"
                         GotFocus="OnTextBoxGotFocus"
                         LostFocus="OnDayLostFocus"
                         KeyDown="OnTextBoxKeyDown"/>
            </Border>
            <RepeatButton Content="&#x25BC;" Style="{StaticResource SpinButton}" Click="OnDayDown"/>
        </StackPanel>

        <!-- Clear button -->
        <Button x:Name="ClearBtn" Content="&#x2715;" Style="{StaticResource ClearButton}"
                Click="OnClear" Margin="6,0,0,0" ToolTip="Clear date"/>
    </StackPanel>
</UserControl>
