<Application x:Class="SynologyPhotoFrame.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SynologyPhotoFrame.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles/TouchStyles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="WpfBoolToVisibilityConverter"/>

            <!-- Simple value converters for UI -->
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:BoolToConnectTextConverter x:Key="BoolToConnectTextConverter"/>
            <converters:BoolToPauseIconConverter x:Key="BoolToPauseIconConverter"/>
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
            <converters:EqualityToVisibilityConverter x:Key="EqualityToVisibilityConverter"/>
            <converters:EqualityToOpacityConverter x:Key="EqualityToOpacityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
